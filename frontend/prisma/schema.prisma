// Prisma schema for Shijie — PostgreSQL (Supabase).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----- NextAuth required models -----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  flashcards    Flashcard[]
  dailyGames    DailyGame[]
  kgNodes       KgNode[]
  kgEdges       KgEdge[]
  script        String      @default("simplified") // "simplified" | "traditional"
  audio         String      @default("mandarin")   // "mandarin" | "cantonese"
  createdAt     DateTime    @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----- App models -----
// One flashcard = one saved word/phrase for a user.
model Flashcard {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hanzi            String
  hanziTraditional String    @default("")
  pinyin           String
  jyutping     String   @default("")
  definition   String
  notes        String?
  // SM-2 spaced repetition fields
  dueAt        DateTime? // null = new card (due immediately)
  interval     Int       @default(1)   // days until next review
  ease         Float     @default(2.5) // ease factor
  reviewCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, hanzi])
  @@index([userId])
  @@index([userId, dueAt])
}

// One daily-image game session for a user (one per local day).
model DailyGame {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey         String   // YYYY-MM-DD UTC
  imageUrl       String
  targetDesc     String?
  difficulty     String?
  targetElements Json?    // array of key elements cached after first attempt
  phraseBank     Json?    // easy/medium vocab chips: [{hanzi, pinyin, jyutping, definition}]
  attempts       Json     @default("[]") // array of {prompt, score, feedback, …}
  attemptsUsed   Int      @default(0)
  solved         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([userId])
}

// ----- Knowledge graph models -----
// A personal vocab graph: each KgNode is a word the user added.
// Edges are derived from radical overlap (character) or shared
// semantic tags (meaning). They're stored explicitly so the UI can
// show them quickly and the quiz mode can pick connected pairs.
model KgNode {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hanzi            String
  hanziTraditional String   @default("")
  pinyin           String
  jyutping     String   @default("")
  definition   String
  radicals     Json     @default("[]") // string[]: shared subcomponents
  components   Json     @default("[]") // string[]: per-character breakdown
  semanticTags Json     @default("[]") // string[]: broad english tags
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  outgoing KgEdge[] @relation("KgEdgeSource")
  incoming KgEdge[] @relation("KgEdgeTarget")

  @@unique([userId, hanzi])
  @@index([userId])
}

model KgEdge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceId  String
  targetId  String
  source    KgNode   @relation("KgEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    KgNode   @relation("KgEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  type      String   // "meaning" | "character"
  reason    String
  weight    Float    @default(1.0)
  createdAt DateTime @default(now())

  @@unique([userId, sourceId, targetId, type])
  @@index([userId])
  @@index([sourceId])
  @@index([targetId])
}
