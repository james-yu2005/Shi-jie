# ====== FRONTEND (frontend/.env.local) ======
# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com -> OAuth client ID -> Web app)
# Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend URL
BACKEND_URL=http://localhost:8000

# Find both in your Supabase dashboard → Project Settings → Database → Connection string
#   Pooled:  postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#   Direct:  postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ====== BACKEND (backend/.env) ======
OPENAI_API_KEY=
# Optional override of model
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
# Optional: comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000
